{
	"name": "@deviltea/eslint-config",
	"type": "module",
	"version": "7.0.0",
	"packageManager": "pnpm@10.14.0",
	"description": "",
	"author": "DevilTea <ch19980814@gmail.com> (https://github.com/DevilTea/)",
	"license": "MIT",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		}
	},
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=20.19.0"
	},
	"scripts": {
		"build": "tsdown src/index.ts --format esm --clean --dts --publint",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"prepublishOnly": "pnpm build",
		"release": "bumpp && pnpm publish"
	},
	"dependencies": {
		"@antfu/eslint-config": "^7.6.1"
	},
	"devDependencies": {
		"bumpp": "^10.4.1",
		"eslint": "^10.0.2",
		"publint": "^0.3.17",
		"tsdown": "^0.20.3",
		"typescript": "~5.9.3"
	}
}
