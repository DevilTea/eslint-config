{
	"name": "@deviltea/eslint-config",
	"type": "module",
	"version": "8.0.2",
	"packageManager": "pnpm@10.34.4",
	"description": "",
	"author": "DevilTea <ch19980814@gmail.com> (https://github.com/DevilTea/)",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/DevilTea/eslint-config.git"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		}
	},
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"build": "tsdown",
		"check": "pnpm test && pnpm lint",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"test": "pnpm build && node --test",
		"prepublishOnly": "pnpm build",
		"release": "bumpp && pnpm publish"
	},
	"dependencies": {
		"@antfu/eslint-config": "^9.1.0"
	},
	"devDependencies": {
		"bumpp": "^11.1.0",
		"eslint": "^10.6.0",
		"publint": "^0.3.21",
		"tsdown": "^0.22.3",
		"typescript": "~5.9.3"
	}
}
